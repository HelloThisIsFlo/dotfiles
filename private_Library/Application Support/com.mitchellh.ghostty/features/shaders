# Custom shaders
# GPU-powered post-processing via GLSL (Shadertoy-compatible)
# Shaders are managed via chezmoi externals (.chezmoiexternal.toml)
# Uncomment to enable — multiple shaders stack in order

# Enable animated shader effects (may use more GPU)
# Values: true | false | always (animate even when terminal isn't updating)
custom-shader-animation = true


# --- Subtle / daily-driver ---

# Soft glow around bright text
# Review: looks amazing in dark mode, but completely broken in light mode — dealbreaker
# custom-shader = ../shaders/community/bloom.glsl

# Dynamic spotlight follows cursor area
# Review: detective show vibes, completely unusable, fun for 20 seconds
# custom-shader = ../shaders/community/spotlight.glsl

# Dithering — retro color reduction
# Review: does what it says, looks horrible
# custom-shader = ../shaders/community/dither.glsl

# Color inversion
# Review: does what it says. Accessibility use case, otherwise why?
# custom-shader = ../shaders/community/negative.glsl

# Animated gradient background
# Review: does what it says, whatever
# custom-shader = ../shaders/community/animated-gradient-shader.glsl

# Static gradient background
# Review: same as animated, whatever
# custom-shader = ../shaders/community/gradient-background.glsl

# TFT display simulation
# Review: screen door effect with giant pixels, looks horrible
# custom-shader = ../shaders/community/tft.glsl


# --- Retro / CRT ---

# Classic CRT scanlines + curvature
# Review: completely broken — pixelated and unreadable
# custom-shader = ../shaders/community/crt.glsl

# Enhanced CRT with more options
# Review: very very cool! Not for daily use but really fun
# custom-shader = ../shaders/community/bettercrt.glsl

# CRT like a monitor inside a video game
# Review: super fun to show off, maybe even cooler than bettercrt, but dark mode only
# custom-shader = ../shaders/community/in-game-crt.glsl

# In-game CRT with cursor styling
# Review: doesn't seem to do anything visible, maybe needs the in-game-crt shader too
# custom-shader = ../shaders/community/in-game-crt-cursor.glsl

# Vintage terminal aesthetics
# Review: greenish CRT, inferior to bettercrt and in-game-crt
