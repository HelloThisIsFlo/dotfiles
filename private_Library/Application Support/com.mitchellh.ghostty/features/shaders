# Tinkle — configurable trail with nice defaults
# custom-shader = ../shaders/trails/tinkle-cursor.glsl

# Wisp — pre-tuned version of tinkle (author's recommendation)
# custom-shader = ../shaders/trails/wisp-cursor.glsl

# Boo — lagging shadow/silhouette of cursor, subtle
# Review: nice and subtle, not incredible. Like a shadow that lags behind, not flashy enough
# custom-shader = ../shaders/trails/boo-cursor.glsl
