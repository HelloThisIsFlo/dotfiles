# --- Cursor effects ---
# Trails activate on cursor movement, booms activate on mode change (block <-> line)

# Neovide-like smooth cursor trail (most customizable)
# Review: the winner — smooth, satisfying, not too much
custom-shader = ../shaders/cursor/cursor_warp.glsl

# Comet-like trail (kitty-style)
# custom-shader = ../shaders/cursor/cursor_tail.glsl

# Shrinking trail from previous to current position
# Review: too basic
# custom-shader = ../shaders/cursor/cursor_sweep.glsl

# Blazing cursor trail — fire effect behind cursor
# Review: cool but a bit much for daily use
# custom-shader = ../shaders/community/cursor_blaze.glsl

# Expanding filled circle on mode change
# custom-shader = ../shaders/cursor/sonic_boom_cursor.glsl

# Circular ring ripple on mode change
custom-shader = ../shaders/cursor/ripple_cursor.glsl

# Rectangular boom on mode change
# custom-shader = ../shaders/cursor/rectangle_boom_cursor.glsl

# Rectangular ripple on mode change
# custom-shader = ../shaders/cursor/ripple_rectangle_cursor.glsl

# --- Cursor trails (hced/ghostty-cursor-trails) ---
