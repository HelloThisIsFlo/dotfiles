# Monaspace font config
# Reference: https://github.com/githubnext/monaspace
# List available features: otfinfo -f ~/Library/Fonts/MonaspaceArgon-Regular.otf

# Mix Monaspace variants for bold/italic — each has a different texture
# Ar=Argon (default), Ne=Neon (sharp), Rn=Radon (handwritten), Kr=Krypton (mechanical), Xe=Xenon (serif)
font-family = Monaspace Argon NF
font-family-bold = Monaspace Krypton NF
font-family-italic = Monaspace Radon NF
font-family-bold-italic = Monaspace Xenon NF


# Texture healing — characters adjust width based on neighbors
font-feature = calt
# Dynamic spacing for repeating chars (///, ||) — avoids triggering on longer sequences
font-feature = liga

# Coding ligatures (stylistic sets)
# ss01: ==, !=, ===, !==
# ss02: <=, >=
# ss03: ->, =>, ~>, <-
# ss04: </>, </, />
# ss05: |>
# ss06: ##, ++, &&
# ss07: ::, =:=
# ss08: ..=, .-
# ss09: <=>, >>, =<<
# ss10: #[, #(
font-feature = ss01
font-feature = ss02
font-feature = ss03
font-feature = ss04
font-feature = ss05
font-feature = ss06
font-feature = ss07
font-feature = ss08
font-feature = ss09
font-feature = ss10

# Character variants — uncomment to enable
# cv01: 0 style (1=plain, 2=slash, 3=reverse slash, 4=cut-out)
# cv02: 1 without serif
# cv10: l, i alternates
# cv11: j, f, r, t alternates
# cv30: * aligned closer to top (Monaspace 1.0 style)
# cv31: * 6-pointed asterisk
# cv32: ≥ ≤ angled lower line
# cv60: <= matches => style instead of rendering ≤
# cv61: [] closed square ligature (can be distracting in editors)
# cv62: @_ ligature
# font-feature = cv01 2
# font-feature = cv02
font-feature = cv10
font-feature = cv11
# font-feature = cv30
font-feature = cv31
font-feature = cv32
