# Quick terminal (dropdown/Quake-style terminal)
# See cheat sheet: quick-terminal.md
# No default keybind — set one in features/keybinds first:
#   keybind = global:ctrl+grave_accent=toggle_quick_terminal

# Which screen edge it slides in from
# Values: top | bottom | left | right | center
# quick-terminal-position = top

# How much screen it covers (percentage or pixels)
# quick-terminal-size = 40%

# Which monitor
# Values: main | mouse | macos-menu-bar
# quick-terminal-screen = main

# Hide when you click away
# quick-terminal-autohide = true

# Slide animation speed (0 for instant)
# quick-terminal-animation-duration = 0

# Follow across macOS Spaces or stay put
# Values: move | remain
# quick-terminal-space-behavior = move
