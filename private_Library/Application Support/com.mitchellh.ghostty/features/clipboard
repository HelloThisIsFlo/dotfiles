# Clipboard
# See cheat sheet: behavior-input.md

# OSC 52 — lets terminal programs (tmux, nvim) read/write system clipboard
# Values: ask | allow | deny
clipboard-read = allow
clipboard-write = allow

# Paste safety
# paste-protection: shows a confirmation dialog when pasting multiline or
#   suspicious content (e.g. commands with trailing newlines that auto-execute)
# paste-bracketed-safe: strips escape sequences inside pasted text that could
#   fake the end of a bracketed paste and inject commands
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true

# Auto-copy selected text to clipboard (just select, no Cmd+C needed)
# Values: true (selection clipboard) | clipboard (system clipboard) | false
copy-on-select = false

# Strip trailing whitespace when copying
clipboard-trim-trailing-spaces = true
