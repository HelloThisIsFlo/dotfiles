## WINNER 🎉
# Mix Monaspace variants for bold/italic — each has a different texture
# Ar=Argon (default), Ne=Neon (sharp), Rn=Radon (handwritten), Kr=Krypton (mechanical), Xe=Xenon (serif)
font-family = Monaspace Argon
font-family-bold = Monaspace Krypton
font-family-italic = Monaspace Radon
font-family-bold-italic = Monaspace Xenon
# font-family = MonaspiceAr Nerd Font Mono
# font-family-bold = MonaspiceKr Nerd Font Mono
# font-family-italic = MonaspiceRn Nerd Font Mono
# font-family-bold-italic = MonaspiceXe Nerd Font Mono

# Font size in points
## 14 is ideal on 1440p (Samsung Odyssey G9)
font-size = 14

# Thicker strokes on macOS Retina — fixes wispy thin fonts
font-thicken = true

# Fine-tune line and character spacing (positive = more space, negative = tighter)
adjust-cell-height = 1
adjust-cell-width = 0
