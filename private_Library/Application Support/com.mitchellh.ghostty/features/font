## WINNER 🎉
# Mix Monaspace variants for bold/italic — each has a different texture
# Ar=Argon (default), Ne=Neon (sharp), Rn=Radon (handwritten), Kr=Krypton (mechanical), Xe=Xenon (serif)
font-family = Monaspace Argon NF
font-family-bold = Monaspace Krypton NF
font-family-italic = Monaspace Radon NF
font-family-bold-italic = Monaspace Xenon NF
# font-family = Monaspace Argon
# font-family-bold = Monaspace Krypton
# font-family-italic = Monaspace Radon
# font-family-bold-italic = Monaspace Xenon
# font-family = MonaspiceAr Nerd Font Mono
# font-family-bold = MonaspiceKr Nerd Font Mono
# font-family-italic = MonaspiceRn Nerd Font Mono
# font-family-bold-italic = MonaspiceXe Nerd Font Mono

# Font size in points
## 14 is ideal on 1440p (Samsung Odyssey G9)
font-size = 14

# Thicker strokes on macOS Retina — fixes wispy thin fonts
font-thicken = true

# Monaspace OpenType features
# List available: otfinfo -f ~/Library/Fonts/MonaspaceArgon-Regular.otf
# Reference: https://github.com/githubnext/monaspace

# Texture healing — characters adjust width based on neighbors
font-feature = calt
# Dynamic spacing for repeating chars (///, ||) — avoids triggering on longer sequences
font-feature = liga

# Coding ligatures (stylistic sets)
font-feature = ss01   # equals:      ==, !=, ===, !==
font-feature = ss02   # comparison:  <=, >=
font-feature = ss03   # arrows:      ->, =>, ~>, <-
font-feature = ss04   # markup:      </>, </, />
font-feature = ss05   # F#/pipe:     |>
font-feature = ss06   # repeated:    ##, ++, &&
font-feature = ss07   # colons:      ::, =:=
font-feature = ss08   # dots:        ..=, .-
font-feature = ss09   # combos:      <=>, >>, =<<
font-feature = ss10   # tags:        #[, #(

# Character variants — uncomment to enable
# Figure variants
# font-feature = cv01 2  # 0 with slash (1=plain, 2=slash, 3=reverse slash, 4=cut-out)
# font-feature = cv02    # 1 without serif
# Letter variants
# font-feature = cv10    # l, i alternates
# font-feature = cv11    # j, f, r, t alternates
# Symbol variants
# font-feature = cv30    # * aligned closer to top (Monaspace 1.0 style)
# font-feature = cv31    # * 6-pointed asterisk
# font-feature = cv32    # ≥ ≤ angled lower line
# Optional ligatures
# font-feature = cv60    # <= matches => style instead of rendering ≤
# font-feature = cv61    # [] closed square ligature (can be distracting in editors)
# font-feature = cv62    # @_ ligature

# Fine-tune line and character spacing (positive = more space, negative = tighter)
adjust-cell-height = 1
adjust-cell-width = 0
