# Font
# See cheat sheet: theme-colors-font.md
# Browse installed fonts: ghostty +list-fonts

# Primary font: Monaspace NF
config-file = font-monaspace

# Font size in points
## 14 is ideal on 1440p (Samsung Odyssey G9)
font-size = 14

# Thicker strokes on macOS Retina — fixes wispy thin fonts
font-thicken = true

# Fine-tune line and character spacing (positive = more space, negative = tighter)
adjust-cell-height = 2
adjust-cell-width = 0
