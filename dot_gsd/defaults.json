{
  "mode": "interactive",
  "model_profile": "quality",
  "commit_docs": true,
  "parallelization": true,
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "auto_advance": false,
    "nyquist_validation": true,
    "ui_phase": false,
    "ui_safety_gate": false,
    "research_before_questions": true,
    "skip_discuss": false,
    "use_worktrees": true
  },
  "git": {
    "branching_strategy": "none"
  },
  "hooks": {
    "context_warnings": false
  },
  "granularity": "coarse",
  "resolve_model_ids": "omit"
}
