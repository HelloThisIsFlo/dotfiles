# Machine classification axes (all orthogonal):
#
#   OS            — automatic via .chezmoi.os (darwin / linux)
#   is_headless   — GUI (false) vs terminal-only (true)
#   trust_level   — what credentials/secrets to place on this machine:
#                     personal  = everything (personal keys, API tokens, .secrets.env)
#                     work      = work credentials only, no personal secrets
#                     untrusted = no credentials at all (shared VPS, Steam Deck, etc.)
#
# Re-prompt all values: `chezmoi init --prompt`

{{ $email := promptStringOnce . "email" "Email address" "flo@kempenich.dev" -}}
{{ $trust_level := promptChoiceOnce . "trust_level" "Trust level (personal = all secrets, work = work only, untrusted = none)" (list "personal" "work" "untrusted") -}}
{{ $is_headless := promptBoolOnce . "is_headless" "Is this a headless machine (no GUI)" false -}}


[data]
    email = {{ $email | quote }}
    trust_level = {{ $trust_level | quote }}
    is_headless = {{ $is_headless }}


[add]
    # Prevent accidentally committing plaintext secrets to the source repo.
    secrets = "error"


[git]
    autoCommit = false


[diff]
    command = "delta"


[[textconv]]
    # Render binary plists as readable XML in diffs.
    pattern = "**/*.plist"
    command = "plutil"
    args = ["-convert", "xml1", "-o", "-", "-"]


[merge]
    # Use VS Code as a 3-way merge editor for conflicts.
    # Init-time: {{ .chezmoi.sourceDir }} is baked into the generated config.
    # Merge-time: {{ "{{ .Source }}" }} etc. are evaluated when `chezmoi merge` runs.
    # Base is the last git-committed version (proper 3-way merge ancestor).
    command = "bash"
    args = [
        "-c",
        'SRCDIR={{ .chezmoi.sourceDir | quote }} && SRC={{ "{{ .Source | quote }}" }} && BASE={{ "{{ printf \"%s.base\" .Target | quote }}" }} && (git -C "$SRCDIR" show "HEAD:${SRC#$SRCDIR/}" > "$BASE" 2>/dev/null || cp {{ "{{ .Target | quote }}" }} "$BASE") && code --new-window --wait --merge {{ "{{ .Target | quote }}" }} {{ "{{ .Destination | quote }}" }} "$BASE" {{ "{{ .Source | quote }}" }}',
    ]


[hooks.read-source-state.pre]
    # Runs before chezmoi reads the source state (i.e. on every chezmoi command).
    # Installs the password manager (rbw) if it's not already on PATH.
    command = ".local/share/chezmoi/.ensure-password-manager-installed.sh"
