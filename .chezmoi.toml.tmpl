# Machine classification axes (all orthogonal):
#
#   os            — macos vs linux (automatic via .chezmoi.os)
#   is_headless   — GUI (false) vs terminal-only (true)
#   trust_level   — what credentials/secrets to place on this machine:
#                     personal  = everything (personal keys, API tokens, .secrets.env)
#                     work      = work credentials only, no personal secrets
#                     untrusted = no credentials at all (shared VPS, Steam Deck, etc.)
#   host_universe — logical constellation of devices this host belongs to
#                     (TheMac / TheHome / DadHome / Other — see prompt below for full breakdown)
#
# Re-prompt all values: `chezmoi init --prompt`

{{ $email := promptStringOnce . "email" "Email address" "flo@kempenich.ai" -}}
{{ $trust_level := promptChoiceOnce . "trust_level" "Trust level (personal = all secrets, work = work only, untrusted = none)" (list "personal" "work" "untrusted") -}}
{{ $is_headless := promptBoolOnce . "is_headless" "Is this a headless machine (no GUI)" false -}}

{{/*
  host_universe — logical constellation of devices/services this host belongs to.
  Used to gate per-machine config (e.g. cloudflared route sync runs only on TheMac).

  Values:
    TheMac  — this MacBook. Local dev services, Cloudflare Tunnel
              (sketchpad/outpost/jay-6.kempenich.dev).
    TheHome — thehome-* cluster. HAOS + Kubernetes + NAS + smart home + tunnels.
    DadHome — dadhome-* cluster. HAOS + NAS + Plex + tunnels (Dad's setup).
    Other   — orphans (DO server, phones, tablets). Default.

  TheHome vs DadHome: both have HAOS + NAS + tunnels.
    TheHome has Kubernetes; DadHome has Plex.
*/}}
{{ $host_universe := promptChoiceOnce . "host_universe" "Which universe does this host belong to?" (list "TheMac" "TheHome" "DadHome" "Other") "Other" -}}


[data]
    # ID
    email = {{ $email | quote }}

    # Machine Settings
    trust_level = {{ $trust_level | quote }}
    is_headless = {{ $is_headless }}
    host_universe = {{ $host_universe | quote }}
{{- if eq .chezmoi.os "darwin" }}
    os = "macos"
{{- else if eq .chezmoi.os "linux" }}
    os = "linux"
{{- end }}

    # Config
    mise_bin = "{{ joinPath .chezmoi.homeDir ".local/bin/mise" }}"


[add]
    # Prevent accidentally committing plaintext secrets to the source repo.
    secrets = "error"


[git]
    autoCommit = false


[diff]
    command = "delta-autotheme"


[[textconv]]
    # Render binary plists as readable XML in diffs.
    pattern = "**/*.plist"
    command = "plutil"
    args = ["-convert", "xml1", "-o", "-", "-"]


[merge]
    # Use VS Code as a 3-way merge editor for conflicts.
    # Init-time: {{ .chezmoi.sourceDir }} is baked into the generated config.
    # Merge-time: {{ "{{ .Source }}" }} etc. are evaluated when `chezmoi merge` runs.
    # Base is the last git-committed version (proper 3-way merge ancestor).
    command = "bash"
    args = [
        "-c",
        'SRCDIR={{ .chezmoi.sourceDir | quote }} && SRC={{ "{{ .Source | quote }}" }} && BASE={{ "{{ printf \"%s.base\" .Target | quote }}" }} && (git -C "$SRCDIR" show "HEAD:${SRC#$SRCDIR/}" > "$BASE" 2>/dev/null || cp {{ "{{ .Target | quote }}" }} "$BASE") && code --new-window --wait --merge {{ "{{ .Target | quote }}" }} {{ "{{ .Destination | quote }}" }} "$BASE" {{ "{{ .Source | quote }}" }}',
    ]


[hooks.read-source-state.pre]
    command = ".local/share/chezmoi/.hooks/run-hooks.sh"
    args = ["read-source-state.pre"]

[hooks.status.pre]
    command = ".local/share/chezmoi/.hooks/run-hooks.sh"
    args = ["status.pre"]
