#!/bin/bash
# Install mise (version manager) — cross-platform, no Homebrew dependency.
# https://mise.jdx.dev/getting-started.html

MISE_INSTALL_PATH="{{ .mise_bin }}" curl https://mise.jdx.dev/install.sh | sh

# There's a bug where tools from aqua are not found after a fresh install, and clearing the cache fixes it.
# I couldn't find any open issues about this, but the workaround is reliable. So, for now, it's staying. 
#
# Added on: 2026-04-03 
# => I may want to revisit this later, to see if it's still needed
#
{{ .mise_bin }} cache clear 
